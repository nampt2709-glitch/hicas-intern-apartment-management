# Copy this file to ".env" next to docker-compose.yml (repository root).
# Never commit .env — it is listed in .gitignore.
#
# Docker Compose reads .env for variable substitution (${SA_PASSWORD}, etc.).
# ASP.NET Core loads the same file via DotEnvLoader when you run `dotnet run` (searches upward from CWD).

# SQL Server SA password — must match the password embedded in ConnectionStrings__DefaultConnection below.
SA_PASSWORD=ChangeMe_StrongPassword123!

# JWT signing key — at least 32 characters. Used as Jwt:Key in configuration.
JWT__KEY=ChangeMe_To_A_Long_Random_Secret_Key_At_Least_32_Chars

# Full connection string when running the API on the host (Visual Studio / dotnet run) against SQL in Docker (port 14330).
# Use the same password as SA_PASSWORD.
ConnectionStrings__DefaultConnection=Server=localhost,14330;Database=HICAS_ApartmentManagementDB;User Id=sa;Password=ChangeMe_StrongPassword123!;TrustServerCertificate=True;Encrypt=False

# Optional — Redis for HybridCache (host machine → Docker Redis on 6379)
Redis__ConnectionString=localhost:6379,abortConnect=false
