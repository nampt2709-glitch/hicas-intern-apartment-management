{
  "info": {
    "name": "Apartment Management API v1.0",
    "description": "Import vào Postman. Chạy **Auth > Login** để script tự set `token`. Các request còn lại dùng Bearer {{token}}. Đổi `baseUrl` nếu cần (Docker mặc định localhost:8080).\n\n`idApartment`, `idUser`, `idUtility`, `purgeUserId` là UUID minh họa (định dạng giống giá trị seed sinh ra; **không** trùng bản ghi thật). Sau khi chạy API/seed, thay bằng id lấy từ response (GET list/detail).\n\nSeed data range: apartments BLK-0001..BLK-0150, bulk users demoblk00..demoblk39@seed.local, canonical accounts admin1/admin2 and user1..user6 @ apartment.local. Các giá trị sample trong collection được đặt trong đúng range seed sinh ra.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "idApartment",
      "value": "8f3e2c1a-9b5d-4f7e-a162-3c4d5e6f7089"
    },
    {
      "key": "idUser",
      "value": "7d2c5e9b-1e4f-4a8c-b243-5f6a7b8c9012"
    },
    {
      "key": "idUtility",
      "value": "6b1e3d8c-0f2a-4b9e-a156-3e4f5a6b7890"
    },
    {
      "key": "purgeUserId",
      "value": "9c2d4e6f-8a0b-4c1d-9258-3f4a5b6c7981"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/login",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin1@apartment.local\",\n  \"password\": \"Admin@12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  const t = j.data?.tokens?.accessToken;",
                  "  if (t) { pm.collectionVariables.set('token', t); }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/register",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Register!1Abc\",\n  \"fullName\": \"New Resident\",\n  \"phoneNumber\": \"+84901234567\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/refresh",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"paste-access-token\",\n  \"refreshToken\": \"paste-refresh-token\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"paste-access-token\",\n  \"refreshToken\": \"paste-refresh-token\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/forgot-password",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user6@apartment.local\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Reset password",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/reset-password",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user6@apartment.local\",\n  \"token\": \"paste-token-from-dev-forgot-response\",\n  \"newPassword\": \"NewStr0ng!Pass\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Me (auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1.0/Auth/me"
          }
        }
      ]
